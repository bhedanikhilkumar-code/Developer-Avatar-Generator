{
    "name":  "developer-avatar-generator",
    "version":  "1.0.0",
    "description":  "Generate deterministic developer avatars as SVG/JSON via CLI, API, and web UI.",
    "type":  "module",
    "main":  "dist/index.js",
    "bin":  {
                "dev-avatar":  "dist/cli.js"
            },
    "scripts":  {
                    "build":  "tsc -p tsconfig.json",
                    "dev":  "tsx src/server.ts",
                    "cli":  "tsx src/cli.ts",
                    "test":  "vitest run",
                    "lint":  "tsc --noEmit",
                    "start":  "node dist/server.js"
                },
    "keywords":  [
                     "avatar",
                     "svg",
                     "developer",
                     "generator",
                     "typescript"
                 ],
    "author":  "",
    "license":  "MIT",
    "dependencies":  {
                         "express":  "^4.19.2"
                     },
    "devDependencies":  {
                            "@types/express":  "^4.17.21",
                            "@types/node":  "^22.12.0",
                            "tsx":  "^4.19.2",
                            "typescript":  "^5.8.2",
                            "vitest":  "^2.1.8"
                        }
}
